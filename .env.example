# consultationAI environment variable example
# Copy this file as needed for local development or deployment reference.
# Do not commit real secrets or real patient data.
# Values below are examples only. Secret-like values are intentionally masked.

# -----------------------------------------------------------------------------
# Frontend: Vercel / Next.js
# -----------------------------------------------------------------------------
# Public backend API URL used by the browser.
NEXT_PUBLIC_API_BASE_URL=https://consultation-api-f1vm.onrender.com

# Clerk public frontend key. This is safe to expose in frontend builds, but keep
# environment-specific values out of committed production configuration.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_********

# Optional Clerk frontend values if your app uses them.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/product
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/product


# -----------------------------------------------------------------------------
# Backend API: Render Web Service / FastAPI
# -----------------------------------------------------------------------------
# Selects the LLM provider path used by the backend.
LLM_PROVIDER=ollama

# Private Render service URL for Ollama.
# This is used only by the backend inside Render's private network.
OLLAMA_BASE_URL=http://consultationai:11434

# Must match the model pulled by the Ollama service.
OLLAMA_MODEL=llama3.2:1b

# Comma-separated list of allowed frontend origins.
# Do not use trailing slashes.
FRONTEND_ORIGINS=https://saas-git-main-bkane56s-projects.vercel.app,https://saas-bice-iota.vercel.app

# Clerk JWKS endpoint used by the backend to validate tokens.
CLERK_JWKS_URL=https://clerk.********.accounts.dev/.well-known/jwks.json

# Optional Clerk backend secret if your backend code requires it.
# Never expose this in frontend/Vercel public variables.
CLERK_SECRET_KEY=sk_test_********

# Render provides PORT automatically for Web Services.
# Keep this only for local testing if needed.
PORT=10000


# -----------------------------------------------------------------------------
# Ollama: Render Private Service
# -----------------------------------------------------------------------------
# Render private service port for Ollama.
PORT=11434

# Makes Ollama listen on all container interfaces.
OLLAMA_HOST=0.0.0.0:11434

# Persistent disk mount path for downloaded Ollama models.
OLLAMA_MODELS=/var/lib/ollama/models

# Model pulled and served by the private Ollama service.
OLLAMA_MODEL=llama3.2:1b


# -----------------------------------------------------------------------------
# Optional local development values
# -----------------------------------------------------------------------------
# Use this when running Ollama locally on your machine.
LOCAL_OLLAMA_BASE_URL=http://localhost:11434

# Local FastAPI API URL if running the backend locally.
LOCAL_API_BASE_URL=http://localhost:8000

# Local frontend origin if running Next.js locally.
LOCAL_FRONTEND_ORIGIN=http://localhost:3000
