{
  "name": "consultationAI",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:api": "bash -lc 'set -a; source .env.local; set +a; .venv/bin/python -m uvicorn api.server:app --reload --port 8000'",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run --coverage",
    "test:ui": "vitest run tests/ui --coverage=false",
    "quality:gates": "yarn lint && yarn test && yarn test:ui"
  },
  "dependencies": {
    "@clerk/nextjs": "^6.37.3",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "next": "15.5.10",
    "react": "19.2.3",
    "react-datepicker": "^9.1.0",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-datepicker": "^7.0.0",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9",
    "eslint-config-next": "15.5.6",
    "jest-axe": "^10.0.0",
    "jsdom": "^26.1.0",
